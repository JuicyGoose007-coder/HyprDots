scan_timeout = 100
command_timeout = 500

"$schema" = "https://starship.rs/config-schema.json"

follow_symlinks = false
add_newline = true

format = """
$os\
$directory\
$git_branch\
${custom.git_worktree}\
$git_status\
$fill\
$cmd_duration\
$jobs\
${env_var.VIM_NORMAL}${env_var.VIM_INSERT}${env_var.VIM_VISUAL}\
$time\
$line_break\
$character\
"""

# palette = "noctalia"

[fill]
symbol = " "

# ============================================================================
# LEFT PROMPT SEGMENTS
# ============================================================================

[os]
disabled = false
style = "fg:teal"
format = "[$symbol ](fg:teal)"

[os.symbols]
Windows = "¾░Ź▓"
Ubuntu = "¾░Ģł"
SUSE = ""
Raspbian = "¾░É┐"
Mint = "¾░ŻŁ"
Macos = ""
Manjaro = ""
Linux = "¾░īĮ"
Gentoo = "¾░Ż©"
Fedora = "¾░Żø"
Alpine = ""
Amazon = ""
Android = ""
Arch = "¾░Żć"
Artix = "¾░Żć"
CachyOS = "¾░īĮ"
CentOS = ""
Debian = "¾░ŻÜ"
Redhat = "¾▒äø"
RedHatEnterprise = "¾▒äø"

[directory]
style = "bold fg:blue"
format = "[$path ]($style)[$read_only]($read_only_style)"
truncation_length = 4
truncation_symbol = "ŌĆ”/"
read_only = "¾░īŠ "
read_only_style = "fg:blue"
home_symbol = "~"

[directory.substitutions]
"Documents" = "¾░łÖ "
"Downloads" = "¾░ćÜ "
"Music" = "¾░Äå "
"Pictures" = "¾░ŗ® "
"Developer" = " "
"Others" = "¾░ē¢ "
"Videos" = "¾░Ģ¦ "
"Desktop" = "¾░¤Ć "
"Projects" = " "
".config" = "¾░Æō "
"repos" = "¾░│É "
"src" = " "

[git_branch]
symbol = " "
style = "fg:green"
format = "[$symbol$branch ]($style)"

[git_status]
format = "([$all_status$ahead_behind](fg:green)) "
style = "fg:green"
staged = "+${count} "
modified = "!${count} "
renamed = "┬╗${count} "
deleted = "Ō£ś${count} "
untracked = "?${count} "
stashed = "*${count} "
conflicted = "~${count} "
ahead = "ŌćĪ${count} "
behind = "ŌćŻ${count} "
diverged = "ŌćĪ${ahead_count}ŌćŻ${behind_count} "
up_to_date = ""

[custom.git_worktree]
description = "Show indicator when inside a git worktree"
command = """
if git rev-parse --git-dir >/dev/null 2>&1; then
      common_dir=$(git rev-parse --path-format=absolute --git-common-dir 2>/dev/null)
      git_dir=$(git rev-parse --path-format=absolute --git-dir 2>/dev/null)
      if [ "$common_dir" != "$git_dir" ]; then
            echo "Ōøō"
      fi
fi
"""
when = "git rev-parse --is-inside-work-tree >/dev/null 2>&1"
format = "([$output ](fg:crust bg:green))"
require_repo = true
ignore_timeout = true

# ============================================================================
# LINE 2 - PROMPT CHARACTER
# ============================================================================

[line_break]
disabled = false

[character]
disabled = false
success_symbol = "[ŌØ»](bold fg:lavender)"
error_symbol = "[ŌØ»](bold fg:red)"
vimcmd_symbol = "[ŌØ«](bold fg:lavender)"

# ============================================================================
# RIGHT PROMPT SEGMENTS
# ============================================================================

[cmd_duration]
min_time = 3000
format = "[¾░ģÉ $duration ](fg:lavender)"
style = "fg:lavender"

[jobs]
format = "[ ¾░£Ä $number ](fg:teal)"
style = "fg:teal"

[time]
disabled = false
time_format = "%I:%M:%S %p"
format = "[ $time ](fg:text)"
style = "fg:text"

[env_var.VIM_NORMAL]
variable = "VIM_NORMAL"
format = "[ $env_value ](bold bg:red fg:crust)"
disabled = false

[env_var.VIM_INSERT]
variable = "VIM_INSERT"
format = "[ $env_value ](bold bg:sky fg:crust)"
disabled = false

[env_var.VIM_VISUAL]
variable = "VIM_VISUAL"
format = "[ $env_value ](bold bg:mauve fg:crust)"
disabled = false

# ============================================================================
# DISABLED
# ============================================================================

[username]
disabled = true

[hostname]
disabled = true

# ============================================================================
# LANGUAGE MODULES
# ============================================================================

[package]
disabled = false
symbol = "¾░Å¢ "
format = " [$symbol$version](fg:text)"

[nodejs]
symbol = "¾░ÄÖ "
format = " [$symbol($version)](fg:green)"

[python]
symbol = "¾░īĀ "
format = " [$symbol($version)](fg:blue)"

[rust]
symbol = "¾▒śŚ "
format = " [$symbol($version)](fg:peach)"

[golang]
symbol = "¾░¤ō "
format = " [$symbol($version)](fg:blue)"
detect_files = ["go.mod"]

[c]
symbol = " "
format = " [$symbol($version)](fg:blue)"

[java]
symbol = "¾░¼Ę "
format = " [$symbol($version)](fg:red)"

[kotlin]
symbol = "¾▒łÖ "
format = " [$symbol($version)](fg:lavender)"

[lua]
symbol = "¾░ó▒ "
format = " [$symbol($version)](fg:blue)"

[ruby]
symbol = "¾░┤Ł "
format = " [$symbol($version)](fg:red)"

[php]
symbol = "¾░ī¤ "
format = " [$symbol($version)](fg:lavender)"

[haskell]
symbol = "¾░▓Æ "
format = " [$symbol($version)](fg:lavender)"

[docker_context]
symbol = "¾░Ī© "
format = " [$symbol($context)](fg:blue)"

[memory_usage]
disabled = true

